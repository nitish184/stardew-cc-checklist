# Copy this file to .env.local and fill in the values.
# .env.local is gitignored (matched by the .env* pattern) and never committed.

# Your Supabase project's API URL.
# Supabase project settings -> API -> Project URL.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# The anon/public key. Safe to expose to the client; reads go through RLS.
# Supabase project settings -> API -> Project API keys -> anon public.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# The service_role secret. Server-only, bypasses RLS — NEVER expose to the client.
# Supabase project settings -> API -> Project API keys -> service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# A secret string you choose. Gates who can check items on the shared board.
BOARD_PASSPHRASE=choose-a-shared-secret
